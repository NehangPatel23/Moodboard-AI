# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by scripts/seed-demo-user.mjs to create the demo account
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Google Gemini free-tier board generation (falls back to demo/mock without it)
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Pexels stock photos for reference images (free, search by title/mood)
# Get a free key: https://www.pexels.com/api/
PEXELS_API_KEY=
