# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by scripts/seed-demo-user.mjs to create the demo account
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Google Gemini free-tier board generation (falls back to demo/mock without it)
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Pexels stock photos for reference images (free, search by title/mood)
# Get a free key: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional — set to "true" when Supabase Realtime "Allow public access" is disabled (requires migrations 016 + 028)
# NEXT_PUBLIC_SUPABASE_REALTIME_PRIVATE=true

# Optional — Unsplash stock photos as fallback when Pexels has no match
# Get a free key: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Optional — Resend transactional email for board collaboration invites (not required — copy invite link works without it)
# Get a free key: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional — canonical site URL for sitemap, OG tags, and invite links (Vercel sets VERCEL_URL automatically)
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
